{
  "expo": {
    "name": "golearrn-mobile",
    "slug": "golearrn-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/app/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#101C2C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.golearrn.mobile"
    },
    "android": {
      "package": "com.golearrn.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/adaptive-icon.png",
        "backgroundColor": "#101C2C"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/app/favicon.png"
    },
    "scheme": "golearrn",
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "f9e91e8f-9fc2-4fca-a162-f42b7dafbcc9"
      }
    },
    "owner": "golearrn01"
  }
}
